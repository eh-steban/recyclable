{
  "name": "MyProject Dev",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/myproject",
  "remoteUser": "lifted",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [
    45297
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "Anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      }
    }
  }
}
