# Shared ignores for the whole repo. Service-specific patterns live in
# backend/.gitignore (Python) and frontend/.gitignore (Node / Next.js).

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Env / secrets / local config
.env
.env.*
!.env.example
*.pem
.mcp.json
.claude/settings.local.json

# Logs
*.log
logs/

# Note: private/ is a git submodule, not gitignored content.
