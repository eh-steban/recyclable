# Shared ignores for the whole repo. Service-specific patterns live in
# backend/.gitignore (Python) and frontend/.gitignore (Node / Next.js).

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Env / secrets / local config
.env
.env.*
!.env.example
*.pem
.mcp.json
.claude/settings.local.json

# Worktree-only compose override (unpublishes ports; see
# docker-compose.override.yaml.example). Never committed -- it would
# unpublish the main checkout's ports too.
docker-compose.override.yaml

# Logs
*.log
logs/

# Note: private/ is a git submodule, not gitignored content.
