# Copy to .env and fill in. Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (local docker-compose)
POSTGRES_USER=recyclable
POSTGRES_PASSWORD=recyclable_dev
POSTGRES_DB=recyclable

# In production:
#   - Vercel:  DATABASE_URL points at Neon
#   - Railway: DATABASE_URL points at Neon (same DB, same env)
DATABASE_URL=postgresql://recyclable:recyclable_dev@localhost:5432/recyclable

# Logging
LOG_LEVEL=INFO
